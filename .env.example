# Kopiera till .env och byt värden innan docker compose up
KARRIAR_PASSWORD=byt-till-starkt-lösenord
# Valfritt – annars härleds från lösenordet (byt lösenord = alla sessioner ogiltiga)
# KARRIAR_SESSION_SECRET=slumpmässig-lång-sträng-minst-32-tecken
# Sätt true bakom HTTPS (AWS + TLS)
KARRIAR_COOKIE_SECURE=false

# Endast finska IP för hela appen inkl. frontend (kräver fi-ipv4.cidr – ingår i Docker-build)
KARRIAR_FINLAND_IP_ONLY=true
# Tillåt localhost/privata nät vid lokal utveckling
KARRIAR_GEOIP_ALLOW_LOCAL=true

# Radera elevdata automatiskt N timmar efter Excel-import
KARRIAR_RETENTION_ENABLED=true
KARRIAR_RETENTION_HOURS=3
